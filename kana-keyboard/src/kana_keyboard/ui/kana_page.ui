<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <template class="KanaPage" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <property name="hexpand">true</property>
    <property name="vexpand">true</property>

    <style>
      <class name="keyboard-page"/>
      <class name="kana-page"/>
    </style>

    <child>
      <object class="GtkBox" id="content">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>

        <child>
          <object class="GtkBox" id="toolbar_box">
            <property name="orientation">horizontal</property>
            <property name="spacing">8</property>
            <property name="hexpand">true</property>

            <child>
              <object class="GtkToggleButton" id="hiragana_button">
                <property name="label">Hiragana</property>
                <property name="active">true</property>
                <signal name="toggled" handler="on_hiragana_toggled"/>
              </object>
            </child>

            <child>
              <object class="GtkToggleButton" id="katakana_button">
                <property name="label">Katakana</property>
                <property name="group">hiragana_button</property>
                <signal name="toggled" handler="on_katakana_toggled"/>
              </object>
            </child>

            <child>
              <object class="GtkToggleButton" id="dakuten_button">
                <property name="label">Dakuten</property>
                <signal name="toggled" handler="on_dakuten_toggled"/>
              </object>
            </child>

            <child>
              <object class="GtkToggleButton" id="handakuten_button">
                <property name="label">Handakuten</property>
                <signal name="toggled" handler="on_handakuten_toggled"/>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkFrame" id="standard_frame">
            <property name="label">Standard kana</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkGrid" id="standard_grid">
                <property name="column-spacing">6</property>
                <property name="row-spacing">6</property>
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkFrame" id="small_frame">
            <property name="label">Small kana</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkGrid" id="small_grid">
                <property name="column-spacing">6</property>
                <property name="row-spacing">6</property>
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkFrame" id="punctuation_frame">
            <property name="label">Punctuation</property>
            <property name="hexpand">true</property>
            <style>
              <class name="card"/>
            </style>
            <child>
              <object class="GtkGrid" id="punctuation_grid">
                <property name="column-spacing">6</property>
                <property name="row-spacing">6</property>
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkExpander" id="yoon_expander">
            <property name="label">Yōon</property>
            <property name="expanded">false</property>
            <property name="hexpand">true</property>

            <child>
              <object class="GtkGrid" id="yoon_grid">
                <property name="column-spacing">6</property>
                <property name="row-spacing">6</property>
                <property name="hexpand">true</property>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>
  </template>
</interface>
